# Trigger Service — Environment Variables

# URL of the agent-runtime service (used by schedule-sweep to fire tasks)
AGENT_RUNTIME_URL=http://localhost:3001

# Port for this service
TRIGGER_SERVICE_PORT=3002

# Webhook HMAC signing secret
WEBHOOK_HMAC_SECRET=

# Email (IMAP) trigger — leave blank to disable
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_TLS=true
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=

# Slack trigger — leave blank to disable
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
