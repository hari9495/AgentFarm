{
    "name": "agentfarm",
    "private": true,
    "version": "0.1.0",
    "packageManager": "pnpm@9.12.0",
    "scripts": {
        "build": "pnpm -r --if-present build",
        "dev": "pnpm --filter @agentfarm/api-gateway dev",
        "lint": "pnpm -r --if-present lint",
        "test": "pnpm -r --if-present test",
        "typecheck": "pnpm -r --if-present typecheck",
        "test:core": "pnpm --filter @agentfarm/api-gateway test && pnpm --filter @agentfarm/agent-runtime test",
        "db:migrate:deploy": "pnpm --filter @agentfarm/db-schema prisma:migrate:deploy",
        "db:backfill:replay": "node scripts/backfill-audit-replay-to-prisma.mjs",
        "test:db-smoke": "pnpm --filter @agentfarm/agent-runtime test:db-smoke",
        "test:db": "bash scripts/run-db-tests.sh",
        "test:db-lane": "pnpm db:migrate:deploy && pnpm test:db-smoke",
        "smoke:e2e": "node scripts/e2e-smoke.mjs",
        "verify:website:prod": "node scripts/website-swa-verify.mjs",
        "quality:gate": "node scripts/quality-gate.mjs"
    },
    "devDependencies": {
        "@types/node": "^22.10.2",
        "c8": "^10.1.3",
        "eslint": "^9.17.0",
        "prettier": "^3.4.2",
        "prisma": "6.0.1",
        "typescript": "^5.7.2"
    }
}