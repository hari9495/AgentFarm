# =============================================================================
# AgentFarm — PRODUCTION environment variables
# =============================================================================
# Usage:
#   1. Copy this file to .env on your production server.
#   2. Fill in every value marked <REQUIRED>.
#   3. NEVER commit a file with real credentials to source control.
#   4. For local development use .env.example instead.
#
# Database naming convention:
#   development  → agentfarm   (or agentfarm_dev)
#   production   → agentfarm_prod
#
# This separation prevents any accidental cross-environment query from
# reaching production data and is required by data durability practice #01.
# =============================================================================

NODE_ENV=production

# -----------------------------------------------------------------------------
# Shared / Infrastructure
# -----------------------------------------------------------------------------

# IMPORTANT: Use a SEPARATE PostgreSQL database from your development database.
# Recommended DB name: agentfarm_prod
DATABASE_URL=postgresql://agentfarm:<REQUIRED:PASSWORD>@<REQUIRED:PROD_HOST>:5432/agentfarm_prod

# Redis — use a dedicated production Redis instance, not your dev instance
REDIS_URL=redis://:<REQUIRED:PASSWORD>@<REQUIRED:PROD_HOST>:6379/0

# OPA (Open Policy Agent) base URL for policy evaluation
OPA_BASE_URL=https://<REQUIRED:OPA_HOST>:8181

# -----------------------------------------------------------------------------
# api-gateway
# -----------------------------------------------------------------------------

API_GATEWAY_PORT=3000

# Must be "true" in production
API_REQUIRE_AUTH=true

# Long random string — min 64 chars, e.g. from: openssl rand -base64 64
API_SESSION_SECRET=<REQUIRED:LONG_RANDOM_STRING>

# Comma-separated allowed CORS origins — list your exact production domains
ALLOWED_ORIGINS=https://<REQUIRED:YOUR_DOMAIN>

# Bearer token for /ops/monitoring endpoints — keep this secret
OPS_MONITORING_TOKEN=<REQUIRED:LONG_RANDOM_STRING>

# Do not enable in production unless you have a full plugin review process
FEATURE_EXTERNAL_PLUGIN_LOADING=false

# Internal base URL of the orchestrator service
ORCHESTRATOR_API_BASE_URL=https://<REQUIRED:ORCHESTRATOR_HOST>

# Internal base URL of the agent-runtime service
AGENT_RUNTIME_URL=https://<REQUIRED:RUNTIME_HOST>

# Shared service-to-service tokens — use distinct secrets per token
RUNTIME_SERVICE_TOKEN=<REQUIRED:LONG_RANDOM_STRING>
APPROVAL_INTAKE_SHARED_TOKEN=<REQUIRED:LONG_RANDOM_STRING>
RUNTIME_DECISION_SHARED_TOKEN=<REQUIRED:LONG_RANDOM_STRING>
CONNECTOR_EXEC_SHARED_TOKEN=<REQUIRED:LONG_RANDOM_STRING>

# -----------------------------------------------------------------------------
# agent-runtime
# -----------------------------------------------------------------------------

AGENT_RUNTIME_PORT=3001

# Must be "true" in production
AGENT_REQUIRE_AUTH=true

# Internal URL of the api-gateway (for approval callbacks)
API_GATEWAY_URL=https://<REQUIRED:GATEWAY_HOST>

# Must match RUNTIME_SERVICE_TOKEN in api-gateway
AGENT_GATEWAY_SHARED_TOKEN=<REQUIRED:LONG_RANDOM_STRING>

# -----------------------------------------------------------------------------
# orchestrator
# -----------------------------------------------------------------------------

ORCHESTRATOR_PORT=3011

# Internal URL of the api-gateway
ORCHESTRATOR_GATEWAY_URL=https://<REQUIRED:GATEWAY_HOST>

# Must match RUNTIME_SERVICE_TOKEN in api-gateway
ORCHESTRATOR_GATEWAY_TOKEN=<REQUIRED:LONG_RANDOM_STRING>

# -----------------------------------------------------------------------------
# Microsoft Teams integration
# -----------------------------------------------------------------------------

TEAMS_APP_ID=<REQUIRED:TEAMS_APP_ID>
TEAMS_APP_PASSWORD=<REQUIRED:TEAMS_APP_PASSWORD>
TEAMS_TENANT_ID=<REQUIRED:AZURE_TENANT_ID>

# -----------------------------------------------------------------------------
# Azure / Entra
# -----------------------------------------------------------------------------

AZURE_TENANT_ID=<REQUIRED:AZURE_TENANT_ID>
AZURE_CLIENT_ID=<REQUIRED:AZURE_CLIENT_ID>
AZURE_CLIENT_SECRET=<REQUIRED:AZURE_CLIENT_SECRET>

# Azure Blob Storage — used for offsite backup uploads (see scripts/db-backup.sh)
AZURE_STORAGE_ACCOUNT=<REQUIRED:STORAGE_ACCOUNT_NAME>
AZURE_STORAGE_KEY=<REQUIRED:STORAGE_ACCOUNT_KEY>
AZURE_BACKUP_CONTAINER=agentfarm-db-backups

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------

# Application Insights connection string
APPLICATIONINSIGHTS_CONNECTION_STRING=<REQUIRED:CONNECTION_STRING>

LOG_LEVEL=warn

# -----------------------------------------------------------------------------
# Dashboard (Next.js)
# -----------------------------------------------------------------------------

# Public URL of the api-gateway — used for server-side and browser fetches
NEXT_PUBLIC_API_URL=https://<REQUIRED:GATEWAY_HOST>

# Must be "true" in production
NEXTAUTH_URL=https://<REQUIRED:DASHBOARD_HOST>
NEXTAUTH_SECRET=<REQUIRED:LONG_RANDOM_STRING>

# -----------------------------------------------------------------------------
# Encryption / signing
# -----------------------------------------------------------------------------

# AES-256 key for encrypting connector credentials at rest (hex, 64 chars)
CONNECTOR_ENCRYPTION_KEY=<REQUIRED:64_CHAR_HEX_STRING>

# HMAC secret for signing webhook payloads
WEBHOOK_SIGNING_SECRET=<REQUIRED:LONG_RANDOM_STRING>
