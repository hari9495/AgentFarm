}

// Frozen 2026-04-21 — canonical source: planning/spec-connector-auth-flow.md
enum ConnectorAuthStatus {
  not_configured
  auth_initiated
  consent_pending
  token_received
  validation_in_progress
  connected
  degraded
  token_expired
  permission_invalid
  revoked
  disconnected
}

enum ConnectorScopeStatus {
  full
  partial
  insufficient
}

enum ConnectorErrorClass {
  oauth_state_mismatch
  oauth_code_exchange_failed
  token_refresh_failed
  token_expired
  insufficient_scope
  provider_rate_limited
  provider_unavailable
  secret_store_unavailable
}

