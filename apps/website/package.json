{
    "name": "@agentfarm/website",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev -p 3002",
        "build": "next build",
        "start": "next start -p 3002",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test:permissions": "pnpm exec tsx --test tests/permissions.test.ts",
        "test:approvals": "pnpm exec tsx --test tests/approvals-flow.test.ts",
        "test:deployments": "pnpm exec tsx --test tests/deployments-flow.test.ts",
        "test:deployments:ui": "pnpm exec tsx --test tests/deployments-history-ui.test.ts",
        "test:signup": "pnpm exec tsx --test tests/signup-flow.test.ts",
        "test:provisioning": "pnpm exec tsx --test tests/provisioning-worker.test.ts",
        "test:session-auth": "pnpm exec tsx --test tests/session-auth.test.ts",
        "test:provisioning-ui": "pnpm exec tsx --test tests/provisioning-progress-ui.test.ts",
        "ui:smoke": "node scripts/ui-smoke.mjs",
        "ui:baseline:verify": "node scripts/verify-ui-baseline.mjs",
        "ui:baseline:update": "node scripts/verify-ui-baseline.mjs --update"
    },
    "dependencies": {
        "@agentfarm/connector-contracts": "workspace:*",
        "@vercel/analytics": "^2.0.1",
        "clsx": "^2.1.1",
        "framer-motion": "^12.36.0",
        "lucide-react": "^0.577.0",
        "next": "^15.1.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-hot-toast": "^2.6.0",
        "tailwind-merge": "^3.5.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^22",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "8.57.0",
        "eslint-config-next": "^15.5.15",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "typescript": "^5"
    }
}