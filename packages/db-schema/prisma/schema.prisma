// Sprint 2 — LLM task execution metadata; canonical source: planning/sprint-1-execution-task-list.md Item 5
model TaskExecutionRecord {
  id               String               @id @default(cuid())
  botId            String
  tenantId         String
  workspaceId      String
  taskId           String
  modelProvider    String
  modelProfile     String
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  latencyMs        Int
  outcome          TaskExecutionOutcome
  executedAt       DateTime
  createdAt        DateTime             @default(now())

  @@index([botId])
  @@index([tenantId])
  @@index([tenantId, executedAt])
  @@index([taskId])
}

enum TaskExecutionOutcome {
  success
  failed
  approval_queued
}

