generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  pending
  provisioning
  ready
  degraded
  suspended
  terminated
}

enum WorkspaceStatus {
  pending
  provisioning
  ready
  degraded
  suspended
  failed
}

enum BotStatus {
  created
  bootstrapping
  connector_setup_required
  active
  paused
  failed
}

