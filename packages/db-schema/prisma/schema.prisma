generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                  String               @id @default(cuid())
  name                String
  status              TenantStatus         @default(pending)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  chatSessions        ChatSession[]
  marketplaceInstalls MarketplaceInstall[]
  orchestrationRuns   OrchestrationRun[]
  scheduledJobs       ScheduledJob[]
  users               TenantUser[]
  workspaces          Workspace[]
}

model TenantUser {
  id           String   @id @default(cuid())
  tenantId     String
  email        String   @unique
  name         String
  passwordHash String
  role         String
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Workspace {
  id        String          @id @default(cuid())
  tenantId  String
  name      String
  status    WorkspaceStatus @default(pending)
  createdAt DateTime        @default(now())
  bot       Bot?
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Bot {
  id             String             @id @default(cuid())
  workspaceId    String             @unique
  role           String
  status         BotStatus          @default(created)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  configVersions BotConfigVersion[]
}

model ProvisioningJob {
  id              String                @id @default(cuid())
  tenantId        String
  workspaceId     String
  botId           String
  planId          String
  runtimeTier     String
  roleType        String
  correlationId   String
  triggerSource   String
  status          ProvisioningJobStatus @default(queued)
  failureReason   String?
  remediationHint String?
  cleanupResult   String?
  requestedAt     DateTime
  requestedBy     String
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  metadata        String?
  orderId         String?
  triggeredBy     String?
  failedAt        DateTime?

  @@index([tenantId])
  @@index([workspaceId])
  @@index([correlationId])
}

model RuntimeInstance {
  id              String        @id @default(cuid())
  botId           String        @unique
  workspaceId     String
  tenantId        String
  status          RuntimeStatus @default(created)
  contractVersion String
  endpoint        String?
  heartbeatAt     DateTime?
  lastSeenAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
  @@index([workspaceId])
}

model BotCapabilitySnapshot {
  id                    String                   @id @default(cuid())
  botId                 String
  tenantId              String
  workspaceId           String
  roleKey               String
  roleVersion           String
  policyPackVersion     String
  allowedConnectorTools String[]
  allowedActions        String[]
  brainConfig           Json
  supportedLanguages    String[]                 @default(["en-US"])
  defaultLanguage       String                   @default("en-US")
  languageTier          String                   @default("base")
  speechProvider        String                   @default("oss")
  translationProvider   String                   @default("oss")
  ttsProvider           String                   @default("oss")
  avatarEnabled         Boolean                  @default(false)
  avatarStyle           String                   @default("audio-only")
  avatarProvider        String                   @default("none")
  avatarLocale          String                   @default("en-US")
  snapshotVersion       Int                      @default(1)
  snapshotChecksum      String?
  source                CapabilitySnapshotSource @default(runtime_freeze)
  frozenAt              DateTime
  createdAt             DateTime                 @default(now())

  @@unique([botId, snapshotVersion])
  @@index([tenantId])
  @@index([workspaceId])
  @@index([botId, frozenAt])
}

model ActionRecord {
  id                String       @id @default(cuid())
  tenantId          String
  workspaceId       String
  botId             String
  actionType        String
  riskLevel         RiskLevel
  policyPackVersion String
  inputSummary      String
  outputSummary     String?
  status            ActionStatus @default(pending)
  approvalId        String?
  connectorType     String?
  correlationId     String
  createdAt         DateTime     @default(now())
  completedAt       DateTime?

  @@index([tenantId])
  @@index([botId])
  @@index([correlationId])
}

model Approval {
  id                       String           @id @default(cuid())
  tenantId                 String
  workspaceId              String
  botId                    String
  taskId                   String
  actionId                 String
  riskLevel                RiskLevel
  actionSummary            String
  requestedBy              String
  approverId               String?
  decision                 ApprovalDecision @default(pending)
  decisionReason           String?
  decisionLatencySeconds   Int?
  policyPackVersion        String
  escalationTimeoutSeconds Int              @default(3600)
  escalatedAt              DateTime?
  createdAt                DateTime         @default(now())
  decidedAt                DateTime?
  llmModel                 String?
  llmProvider              String?

  @@index([tenantId])
  @@index([workspaceId])
  @@index([botId])
  @@index([taskId])
  @@index([decision])
  @@index([riskLevel])
  @@index([decisionLatencySeconds])
}

model AuditEvent {
  id            String         @id @default(cuid())
  tenantId      String
  workspaceId   String
  botId         String
  eventType     AuditEventType
  severity      AuditSeverity  @default(info)
  summary       String
  sourceSystem  String
  correlationId String
  createdAt     DateTime       @default(now())

  @@index([tenantId])
  @@index([botId])
  @@index([correlationId])
  @@index([createdAt])
}

model ConnectorAuthMetadata {
  id                String                @id @default(cuid())
  connectorId       String                @unique
  tenantId          String
  workspaceId       String
  connectorType     String
  authMode          String
  status            ConnectorAuthStatus   @default(not_configured)
  grantedScopes     String[]
  scopeStatus       ConnectorScopeStatus?
  secretRefId       String?
  tokenExpiresAt    DateTime?
  lastRefreshAt     DateTime?
  lastErrorClass    ConnectorErrorClass?
  lastHealthcheckAt DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([tenantId])
  @@index([workspaceId])
  @@index([status])
}

model ConnectorAuthSession {
  id          String   @id @default(cuid())
  connectorId String
  tenantId    String
  workspaceId String
  stateNonce  String   @unique
  status      String
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([connectorId])
  @@index([tenantId])
}

model ConnectorAuthEvent {
  id            String               @id @default(cuid())
  connectorId   String
  tenantId      String
  eventType     String
  result        String
  errorClass    ConnectorErrorClass?
  correlationId String
  actor         String
  createdAt     DateTime             @default(now())

  @@index([connectorId])
  @@index([tenantId])
  @@index([correlationId])
}

model ConnectorAction {
  id                   String                    @id @default(cuid())
  actionId             String                    @unique
  tenantId             String
  workspaceId          String
  botId                String
  connectorId          String
  connectorType        String
  actionType           ConnectorActionType
  contractVersion      String                    @default("v1.0")
  correlationId        String
  requestBody          Json
  resultStatus         ConnectorActionStatus
  providerResponseCode String?
  resultSummary        String
  errorCode            ConnectorActionErrorCode?
  errorMessage         String?
  remediationHint      String?
  completedAt          DateTime
  createdAt            DateTime                  @default(now())

  @@index([tenantId])
  @@index([botId])
  @@index([correlationId])
  @@index([connectorType])
}

model TaskExecutionRecord {
  id               String               @id @default(cuid())
  botId            String
  tenantId         String
  workspaceId      String
  taskId           String
  modelProvider    String
  modelProfile     String
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  latencyMs        Int
  outcome          TaskExecutionOutcome
  executedAt       DateTime
  createdAt        DateTime             @default(now())
  estimatedCostUsd Float?
  modelTier        String?

  @@index([botId])
  @@index([tenantId])
  @@index([tenantId, executedAt])
  @@index([taskId])
}

model WorkspaceSessionState {
  id          String   @id @default(cuid())
  tenantId    String
  workspaceId String
  version     Int
  state       Json
  updatedBy   String
  updatedAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([tenantId, workspaceId])
  @@index([tenantId])
  @@index([workspaceId])
}

model WorkspaceCheckpoint {
  id             String   @id @default(cuid())
  tenantId       String
  workspaceId    String
  sessionVersion Int
  label          String
  reason         String?
  stateDigest    String?
  actor          String
  createdAt      DateTime
  correlationId  String

  @@index([tenantId])
  @@index([workspaceId])
  @@index([tenantId, workspaceId])
  @@index([createdAt])
  @@index([correlationId])
}

model DesktopProfile {
  id            String    @id @default(cuid())
  tenantId      String
  workspaceId   String
  profileId     String    @unique
  browser       String
  storageRef    String?
  tabState      Json
  tokenVersion  Int       @default(1)
  lastRotatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, workspaceId])
  @@index([tenantId])
  @@index([workspaceId])
}

model IdeState {
  id          String   @id @default(cuid())
  tenantId    String
  workspaceId String
  openFiles   Json     @default("[]")
  activeFile  String?
  breakpoints Json     @default("[]")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, workspaceId])
  @@index([tenantId])
  @@index([workspaceId])
}

model TerminalSession {
  id          String   @id @default(cuid())
  tenantId    String
  workspaceId String
  shell       String   @default("bash")
  cwd         String   @default("/")
  lastCommand String?
  history     Json     @default("[]")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([workspaceId])
  @@index([tenantId, workspaceId])
}

model ActivityEvent {
  id            String    @id @default(cuid())
  tenantId      String
  workspaceId   String
  category      String
  title         String
  body          String?
  payload       Json?
  status        String    @default("unread")
  sequence      Int
  ackedAt       DateTime?
  ackedBy       String?
  correlationId String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
  @@index([workspaceId])
  @@index([tenantId, workspaceId, sequence])
  @@index([tenantId, workspaceId, status])
}

model EnvProfile {
  id              String    @id @default(cuid())
  tenantId        String
  workspaceId     String
  toolchain       Json      @default("[]")
  reconcileStatus String    @default("clean")
  lastReconcileAt DateTime?
  driftReport     Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, workspaceId])
  @@index([tenantId])
  @@index([workspaceId])
}

model DesktopAction {
  id            String    @id @default(cuid())
  tenantId      String
  workspaceId   String
  actionType    String
  target        String?
  inputPayload  Json?
  result        String    @default("success")
  riskLevel     String    @default("low")
  retryClass    String    @default("retryable")
  retryCount    Int       @default(0)
  screenshotRef String?
  approvalId    String?
  errorMessage  String?
  completedAt   DateTime?
  correlationId String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
  @@index([workspaceId])
  @@index([tenantId, workspaceId])
  @@index([approvalId])
}

model PrDraft {
  id                 String   @id @default(cuid())
  tenantId           String
  workspaceId        String
  branch             String
  targetBranch       String?
  changeSummary      String
  linkedIssueIds     Json     @default("[]")
  title              String
  body               String
  checklist          Json     @default("[]")
  reviewersSuggested Json     @default("[]")
  status             String   @default("draft")
  prId               String?
  provider           String?
  labels             Json     @default("[]")
  correlationId      String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId, workspaceId])
  @@index([tenantId, workspaceId, status])
}

model CiTriageReport {
  id                  String   @id @default(cuid())
  tenantId            String
  workspaceId         String
  provider            String
  runId               String
  repo                String
  branch              String
  failedJobs          Json     @default("[]")
  logRefs             Json     @default("[]")
  status              String   @default("queued")
  rootCauseHypothesis String?
  reproSteps          Json?
  patchProposal       String?
  confidence          Float?
  blastRadius         String?
  correlationId       String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([tenantId, workspaceId, runId])
  @@index([tenantId, workspaceId])
  @@index([tenantId, workspaceId, status])
}

model WorkMemory {
  id            String   @id @default(cuid())
  tenantId      String
  workspaceId   String
  memoryVersion Int      @default(1)
  entries       Json     @default("[]")
  summary       String?
  correlationId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, workspaceId])
  @@index([tenantId, workspaceId])
}

model StoredEvidenceBundle {
  id            String    @id @default(cuid())
  taskId        String
  tenantId      String
  workspaceId   String
  botId         String
  actionType    String
  riskLevel     String
  routeDecision String
  llmProvider   String
  inputTokens   Int
  outputTokens  Int
  screenshots   String[]
  approvalId    String?
  signature     String?
  finalised     Boolean   @default(false)
  finalisedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([tenantId])
  @@index([workspaceId])
  @@index([taskId])
  @@index([tenantId, workspaceId])
}

model RunResume {
  id            String   @id @default(cuid())
  tenantId      String
  workspaceId   String
  runId         String
  strategy      String
  resumedFrom   String?
  status        String   @default("queued")
  failureReason String?
  correlationId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, workspaceId])
  @@index([tenantId, workspaceId, runId])
}

model ReproPack {
  id                 String   @id @default(cuid())
  tenantId           String
  workspaceId        String
  runId              String
  status             String   @default("generating")
  manifest           Json
  downloadRef        String?
  expiresAt          DateTime
  exportAuditEventId String?
  correlationId      String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId, workspaceId])
  @@index([tenantId, workspaceId, runId])
}

model AgentDispatchRecord {
  id                 String            @id @default(cuid())
  fromAgentId        String
  toAgentId          String
  workspaceId        String
  tenantId           String
  taskDescription    String
  status             String            @default("queued")
  wakeSource         String            @default("agent_handoff")
  queuedAt           DateTime          @default(now())
  createdAt          DateTime          @default(now())
  completedAt        DateTime?
  errorMessage       String?
  orchestrationRunId String?
  result             Json?
  subTaskIndex       Int?
  orchestrationRun   OrchestrationRun? @relation(fields: [orchestrationRunId], references: [id])

  @@index([tenantId, workspaceId])
  @@index([tenantId, queuedAt])
  @@index([orchestrationRunId])
}

model AgentShortTermMemory {
  id               String    @id @default(cuid())
  workspaceId      String
  tenantId         String
  taskId           String
  actionsTaken     Json
  approvalOutcomes Json
  connectorsUsed   Json
  llmProvider      String?
  executionStatus  String    @default("success")
  summary          String
  correlationId    String
  createdAt        DateTime  @default(now())
  expiresAt        DateTime?
  repoName         String?

  @@index([workspaceId, createdAt])
  @@index([workspaceId, expiresAt])
  @@index([tenantId])
}

model AgentLongTermMemory {
  id            String   @id @default(cuid())
  tenantId      String
  workspaceId   String
  pattern       String
  confidence    Float
  observedCount Int      @default(1)
  lastSeen      DateTime
  createdAt     DateTime @default(now())
  repoName      String?

  @@unique([tenantId, pattern])
  @@index([workspaceId, confidence])
  @@index([tenantId, workspaceId])
}

model AgentRepoKnowledge {
  id          String   @id @default(cuid())
  tenantId    String
  workspaceId String
  repoName    String
  role        String
  key         String
  value       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, repoName, role, key])
  @@index([tenantId, repoName, role])
  @@index([workspaceId])
}

model AgentSession {
  id                 String               @id @unique
  tenantId           String
  agentInstanceId    String
  taskId             String
  role               String
  recordingId        String
  recordingUrl       String
  startedAt          DateTime
  endedAt            DateTime?
  actionCount        Int                  @default(0)
  status             SessionAuditStatus   @default(running)
  failureReason      String?
  retentionExpiresAt DateTime?
  retentionPolicyId  String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  actions            BrowserActionEvent[]

  @@index([tenantId])
  @@index([agentInstanceId])
  @@index([taskId])
  @@index([tenantId, startedAt])
  @@index([status])
  @@index([retentionExpiresAt])
}

model BrowserActionEvent {
  id                    String            @id @unique
  sessionId             String
  tenantId              String
  agentInstanceId       String
  sequence              Int
  actionType            BrowserActionType
  targetSelector        String
  targetText            String
  inputValue            String?
  pageUrl               String
  screenshotBeforeId    String
  screenshotAfterId     String
  screenshotBeforeUrl   String
  screenshotAfterUrl    String
  domSnapshotHashBefore String?
  domSnapshotHashAfter  String?
  networkLog            Json              @default("[]")
  durationMs            Int
  success               Boolean
  errorMessage          String?
  failureClass          String?
  timestamp             DateTime
  correctnessAssertion  Json?
  createdAt             DateTime          @default(now())
  session               AgentSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([tenantId])
  @@index([agentInstanceId])
  @@index([tenantId, actionType])
  @@index([timestamp])
  @@index([tenantId, timestamp])
}

model RetentionPolicy {
  id               String                @id @default(cuid())
  tenantId         String
  workspaceId      String?
  roleKey          String?
  name             String
  description      String?
  scope            RetentionPolicyScope  @default(tenant)
  action           RetentionPolicyAction @default(never_delete)
  retentionDays    Int?
  deletionTrigger  String?
  deletionSchedule String?
  effectiveFrom    DateTime
  expiredAt        DateTime?
  status           RetentionPolicyStatus @default(active)
  createdBy        String
  updatedBy        String
  correlationId    String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([tenantId])
  @@index([tenantId, workspaceId])
  @@index([tenantId, status])
}

model AgentQuestion {
  id              String                     @id @default(cuid())
  contractVersion String
  tenantId        String
  workspaceId     String
  taskId          String
  botId           String
  question        String
  context         String
  options         String[]                   @default([])
  askedVia        AgentQuestionChannel
  status          AgentQuestionStatus        @default(pending)
  timeoutMs       Int                        @default(14400000)
  onTimeout       AgentQuestionTimeoutPolicy @default(escalate)
  answer          String?
  answeredBy      String?
  answeredAt      DateTime?
  expiresAt       DateTime
  correlationId   String
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@index([tenantId])
  @@index([workspaceId])
  @@index([taskId])
  @@index([status])
  @@index([expiresAt])
  @@index([tenantId, status])
}

model TenantMcpServer {
  id          String   @id @default(cuid())
  tenantId    String
  workspaceId String?
  name        String
  url         String
  headers     Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

model TenantLanguageConfig {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  defaultLanguage String   @default("en")
  ticketLanguage  String   @default("en")
  autoDetect      Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
}

model WorkspaceLanguageConfig {
  id                String   @id @default(cuid())
  tenantId          String
  workspaceId       String
  preferredLanguage String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, workspaceId])
  @@index([tenantId])
}

model UserLanguageProfile {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String
  detectedLanguage  String?
  preferredLanguage String?
  confidence        Float     @default(0.0)
  lastDetectedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([tenantId, userId])
}

model MeetingSession {
  id               String    @id @default(cuid())
  tenantId         String
  workspaceId      String
  agentId          String
  meetingUrl       String
  platform         String
  status           String    @default("joining")
  language         String?
  transcriptRaw    String?
  summaryText      String?
  actionItems      String?
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  updatedAt        DateTime  @updatedAt
  agentVoiceId     String?
  resolvedLanguage String?
  speakingEnabled  Boolean   @default(false)

  @@index([tenantId])
  @@index([workspaceId])
  @@index([tenantId, workspaceId])
  @@index([tenantId, status])
}

model Plan {
  id                  String               @id @default(cuid())
  name                String
  priceInr            Int
  priceUsd            Int
  agentSlots          Int
  features            String
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  agentSubscriptions  AgentSubscription[]
  orders              Order[]
  tenantSubscriptions TenantSubscription[]
}

model Order {
  id                String    @id @default(cuid())
  tenantId          String
  planId            String
  amountCents       Int
  currency          String
  status            String    @default("pending")
  paymentProvider   String
  providerOrderId   String?
  providerPaymentId String?
  providerSignature String?
  customerEmail     String
  customerCountry   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  contractPdfUrl    String?
  contractSentAt    DateTime?
  signatureStatus   String?   @default("pending")
  signedAt          DateTime?
  zohoSignRequestId String?
  invoice           Invoice?
  plan              Plan      @relation(fields: [planId], references: [id])
}

model Invoice {
  id          String    @id @default(cuid())
  orderId     String    @unique
  tenantId    String
  number      String    @unique
  amountCents Int
  currency    String
  pdfUrl      String?
  sentAt      DateTime?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  order       Order     @relation(fields: [orderId], references: [id])
}

model ExternalPluginLoad {
  id              String   @id @default(cuid())
  tenantId        String
  pluginKey       String
  version         String
  status          String
  trustLevel      String
  rejectionReason String?
  loadedAt        DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, pluginKey])
}

model PluginKillSwitch {
  id        String   @id @default(cuid())
  tenantId  String
  pluginKey String
  reason    String?
  killedAt  DateTime @default(now())
  killedBy  String?

  @@unique([tenantId, pluginKey])
}

model PluginAllowlist {
  id           String   @id @default(cuid())
  tenantId     String
  pluginKey    String
  capabilities String[]
  grantedAt    DateTime @default(now())

  @@unique([tenantId, pluginKey])
}

model NotificationLog {
  id           String   @id @default(cuid())
  tenantId     String
  workspaceId  String?
  channel      String
  eventTrigger String
  status       String
  payload      Json?
  error        String?
  sentAt       DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, sentAt])
}

model QualitySignalLog {
  id          String   @id @default(cuid())
  tenantId    String
  workspaceId String
  taskId      String?
  signalType  String?
  source      String?
  score       Float?
  metadata    Json?
  recordedAt  DateTime @default(now())

  @@index([tenantId])
  @@index([workspaceId, taskId])
}

model TenantSubscription {
  id              String              @id @default(cuid())
  tenantId        String              @unique
  planId          String
  status          SubscriptionStatus  @default(active)
  paymentProvider String
  startedAt       DateTime
  expiresAt       DateTime
  gracePeriodDays Int                 @default(3)
  suspendedAt     DateTime?
  cancelledAt     DateTime?
  reactivatedAt   DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  agentSubs       AgentSubscription[]
  events          SubscriptionEvent[]
  plan            Plan                @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([expiresAt])
  @@index([tenantId, status])
}

model AgentSubscription {
  id                   String              @id @default(cuid())
  tenantId             String
  agentId              String
  tenantSubscriptionId String?
  planId               String
  status               SubscriptionStatus  @default(active)
  paymentProvider      String
  startedAt            DateTime
  expiresAt            DateTime
  gracePeriodDays      Int                 @default(3)
  suspendedAt          DateTime?
  cancelledAt          DateTime?
  reactivatedAt        DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  plan                 Plan                @relation(fields: [planId], references: [id])
  tenantSubscription   TenantSubscription? @relation(fields: [tenantSubscriptionId], references: [id])
  events               SubscriptionEvent[]

  @@unique([tenantId, agentId])
  @@index([tenantId])
  @@index([agentId])
  @@index([status])
  @@index([expiresAt])
  @@index([tenantId, status])
}

model SubscriptionEvent {
  id                   String                 @id @default(cuid())
  tenantId             String
  tenantSubscriptionId String?
  agentSubscriptionId  String?
  fromStatus           SubscriptionStatus?
  toStatus             SubscriptionStatus
  actor                SubscriptionEventActor
  paymentProvider      String?
  providerEventId      String?
  reason               String?
  metadata             Json?
  occurredAt           DateTime               @default(now())
  agentSubscription    AgentSubscription?     @relation(fields: [agentSubscriptionId], references: [id])
  tenantSubscription   TenantSubscription?    @relation(fields: [tenantSubscriptionId], references: [id])

  @@index([tenantId])
  @@index([tenantSubscriptionId])
  @@index([agentSubscriptionId])
  @@index([tenantId, occurredAt])
}

model OutboundWebhook {
  id           String                    @id @default(cuid())
  tenantId     String
  workspaceId  String?
  url          String
  secret       String
  events       String[]
  enabled      Boolean                   @default(true)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  dlqAt        DateTime?
  failureCount Int                       @default(0)
  deliveries   OutboundWebhookDelivery[]
  dlqEntries   WebhookDlqEntry[]

  @@index([tenantId])
  @@index([tenantId, enabled])
}

model OutboundWebhookDelivery {
  id             String          @id @default(cuid())
  webhookId      String
  tenantId       String
  eventType      String
  payload        Json
  responseStatus Int?
  responseBody   String?
  durationMs     Int?
  success        Boolean
  firedAt        DateTime        @default(now())
  webhook        OutboundWebhook @relation(fields: [webhookId], references: [id])

  @@index([webhookId])
  @@index([tenantId])
  @@index([webhookId, firedAt])
}

model WebhookDlqEntry {
  id            String          @id @default(cuid())
  webhookId     String
  tenantId      String
  reason        String
  lastPayload   Json
  lastEventType String
  createdAt     DateTime        @default(now())
  resolvedAt    DateTime?
  resolvedBy    String?
  webhook       OutboundWebhook @relation(fields: [webhookId], references: [id])

  @@index([tenantId])
  @@index([webhookId])
}

model ScheduledJob {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  cronExpr  String
  goal      String
  agentId   String?
  enabled   Boolean   @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, enabled])
}

model ChatSession {
  id        String        @id @default(cuid())
  tenantId  String
  agentId   String?
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model BotConfigVersion {
  id                String   @id @default(cuid())
  botId             String
  tenantId          String
  versionNumber     Int
  role              String
  status            String
  roleVersion       String?
  policyPackVersion String?
  brainConfig       Json?
  changeNote        String?
  createdBy         String
  createdAt         DateTime @default(now())
  bot               Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, versionNumber])
  @@index([botId])
  @@index([tenantId])
}

model OrchestrationRun {
  id               String                @id @default(cuid())
  tenantId         String
  workspaceId      String
  coordinatorBotId String
  goal             String
  status           String                @default("running")
  subTaskCount     Int                   @default(0)
  completedCount   Int                   @default(0)
  failedCount      Int                   @default(0)
  result           Json?
  errorSummary     String?
  startedAt        DateTime              @default(now())
  completedAt      DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  dispatches       AgentDispatchRecord[]
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

model MarketplaceListing {
  id          String               @id @default(cuid())
  skillId     String               @unique
  name        String
  description String?
  version     String
  author      String?
  permissions Json                 @default("[]")
  source      String?
  tags        Json                 @default("[]")
  status      String               @default("active")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  installs    MarketplaceInstall[]

  @@index([status])
}

model MarketplaceInstall {
  id                  String             @id @default(cuid())
  tenantId            String
  skillId             String
  listingId           String
  approvedPermissions Json               @default("[]")
  pinVersion          Boolean            @default(false)
  status              String             @default("installed")
  installedAt         DateTime           @default(now())
  uninstalledAt       DateTime?
  listing             MarketplaceListing @relation(fields: [listingId], references: [id])
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, skillId])
  @@index([tenantId])
  @@index([tenantId, status])
}

model AbTest {
  id             String             @id @default(cuid())
  tenantId       String
  botId          String
  name           String
  versionAId     String
  versionBId     String
  trafficSplit   Float              @default(0.5)
  status         String             @default("active")
  conclusionNote String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  assignments    AbTestAssignment[]

  @@index([tenantId])
  @@index([tenantId, botId])
  @@index([tenantId, status])
}

model AbTestAssignment {
  id        String   @id @default(cuid())
  abTestId  String
  tenantId  String
  taskId    String   @unique
  versionId String
  variant   String
  createdAt DateTime @default(now())
  abTest    AbTest   @relation(fields: [abTestId], references: [id])

  @@index([abTestId])
  @@index([tenantId])
  @@index([taskId])
}

model AgentRateLimit {
  id                String   @id @default(cuid())
  botId             String   @unique
  tenantId          String
  requestsPerMinute Int      @default(60)
  burstLimit        Int      @default(10)
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
}

model CircuitBreakerState {
  id            String    @id @default(cuid())
  key           String    @unique
  tenantId      String
  state         String    @default("closed")
  failureCount  Int       @default(0)
  lastFailureAt DateTime?
  openedAt      DateTime?
  nextRetryAt   DateTime?
  successCount  Int       @default(0)
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, state])
}

model TaskQueueEntry {
  id           String    @id @default(cuid())
  tenantId     String
  workspaceId  String
  botId        String?
  priority     String    @default("normal")
  status       String    @default("pending")
  payload      Json
  errorMessage String?
  enqueuedAt   DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority, enqueuedAt])
}

model ScheduledReport {
  id             String    @id @default(cuid())
  tenantId       String
  workspaceId    String
  name           String
  recipientEmail String
  frequency      String    @default("weekly")
  reportTypes    String[]
  enabled        Boolean   @default(true)
  lastSentAt     DateTime?
  nextSendAt     DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, enabled])
  @@index([nextSendAt, enabled])
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  createdBy  String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  scopes     String[]
  role       String    @default("operator")
  enabled    Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId])
  @@index([keyHash])
  @@index([tenantId, enabled])
}

// ── Sales pipeline ─────────────────────────────────────────────────────────

model SalesAgentConfig {
  id                 String   @id @default(cuid())
  tenantId           String
  botId              String   @unique
  productDescription String
  icp                String
  leadSourceProvider String
  emailProvider      String
  crmProvider        String
  calendarProvider   String
  signatureProvider  String
  emailTone          String   @default("conversational")
  followUpDays       Int[]    @default([3, 7, 14])
  maxProspectsPerDay Int      @default(50)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId])
  @@index([botId])
}

model Prospect {
  id              String         @id @default(cuid())
  tenantId        String
  botId           String
  firstName       String
  lastName        String
  email           String
  company         String
  title           String?
  industry        String?
  companySize     String?
  linkedinUrl     String?
  website         String?
  phone           String?
  icpScore        Int            @default(0)
  qualified       Boolean        @default(false)
  status          ProspectStatus @default(new)
  notes           String?
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  deals      SalesDeal[]
  activities SalesActivity[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([botId])
  @@index([tenantId, status])
}

model SalesDeal {
  id                String    @id @default(cuid())
  tenantId          String
  botId             String
  prospectId        String
  title             String
  value             Float?
  currency          String    @default("USD")
  stage             DealStage @default(discovery)
  notes             String?
  expectedCloseDate DateTime?
  closedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  prospect   Prospect        @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  activities SalesActivity[]

  @@index([tenantId])
  @@index([botId])
  @@index([prospectId])
  @@index([tenantId, stage])
}

model SalesActivity {
  id           String            @id @default(cuid())
  tenantId     String
  botId        String
  prospectId   String
  dealId       String?
  activityType SalesActivityType
  subject      String
  body         String?
  outcome      String?
  scheduledAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  prospect Prospect   @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  deal     SalesDeal? @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([botId])
  @@index([prospectId])
  @@index([dealId])
}

