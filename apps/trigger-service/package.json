        "nodemailer": "^6.10.1"
    },
    "devDependencies": {
        "@types/mailparser": "^3.4.6",
        "@types/nodemailer": "^6.4.17",
        "@types/node": "^22.0.0",
        "tsx": "^4.20.6",
        "typescript": "^5.7.2"
    }
}