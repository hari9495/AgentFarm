# =============================================================================
# AgentFarm — consolidated environment variable reference
# Copy this file to .env and fill in values for your environment.
# Vars marked AF_* also accept an AGENTFARM_* alias as a fallback unless noted.
# Secrets should never be committed; use your-secret-here as a placeholder.
# =============================================================================

# -----------------------------------------------------------------------------
# Shared / Infrastructure
# -----------------------------------------------------------------------------

# PostgreSQL connection string used by all services that write to the DB
DATABASE_URL=postgresql://agentfarm:agentfarm@localhost:5432/agentfarm

# Redis connection string used for caching and pub/sub
REDIS_URL=redis://localhost:6379

# OPA (Open Policy Agent) base URL for policy evaluation
OPA_BASE_URL=http://localhost:8181

# -----------------------------------------------------------------------------
# api-gateway  (apps/api-gateway)
# -----------------------------------------------------------------------------

# Port the API gateway HTTP server listens on
API_GATEWAY_PORT=3000

# Set to "true" to enforce bearer-token auth on all routes
API_REQUIRE_AUTH=false

# Secret used to sign session cookies; change this in production
API_SESSION_SECRET=your-secret-here

# Comma-separated allowed CORS origins in production; unset = allow all in dev
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# Bearer token required for /ops/monitoring endpoints
OPS_MONITORING_TOKEN=your-secret-here

# Feature flag: allow loading external plugins at runtime
FEATURE_EXTERNAL_PLUGIN_LOADING=false

# Base URL of the orchestrator service (used by handoff routes)
ORCHESTRATOR_API_BASE_URL=http://localhost:3011

# Base URL of the agent-runtime service (used by chat proxy and schedule proxy routes)
AGENT_RUNTIME_URL=http://localhost:3001

# Shared token that agent-runtime uses to authenticate inbound calls to the gateway
RUNTIME_SERVICE_TOKEN=your-secret-here

# Shared token for the approval intake endpoint (AF_APPROVAL_INTAKE_SHARED_TOKEN also accepted)
APPROVAL_INTAKE_SHARED_TOKEN=your-secret-here

# Shared token for runtime decision callbacks (AGENTFARM_RUNTIME_DECISION_SHARED_TOKEN also accepted)
RUNTIME_DECISION_SHARED_TOKEN=your-secret-here

# Shared token for connector execution callbacks (AGENTFARM_CONNECTOR_EXEC_SHARED_TOKEN also accepted)
CONNECTOR_EXEC_SHARED_TOKEN=your-secret-here

# Shared token used when dispatching tasks to the runtime (AF_RUNTIME_DISPATCH_SHARED_TOKEN also accepted)
RUNTIME_DISPATCH_SHARED_TOKEN=your-secret-here

# Shared token for runtime-task observability push (AGENTFARM_RUNTIME_TASK_SHARED_TOKEN also accepted)
RUNTIME_TASK_SHARED_TOKEN=your-secret-here

# Bearer token protecting the SSE internal-push endpoint
SSE_INTERNAL_TOKEN=your-secret-here

# URL of the SSE push endpoint used by internal services to broadcast events
SSE_PUSH_URL=http://localhost:3001/sse-push

# Slack incoming webhook URL for agent-question escalation notifications
AGENT_QUESTION_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# HMAC secret for generic inbound webhooks
WEBHOOK_INGEST_SECRET=your-secret-here

# HMAC secret for Slack inbound webhooks
SLACK_WEBHOOK_SECRET=your-secret-here

# HMAC secret for Microsoft Teams inbound webhooks
TEAMS_WEBHOOK_SECRET=your-secret-here

# HMAC secret for memory-sync inbound webhooks
MEMORY_WEBHOOK_SECRET=your-secret-here

# Comma-separated domains allowed for internal login (deny-all if unset)
API_INTERNAL_LOGIN_ALLOWED_DOMAINS=agentfarm.local

# Comma-separated roles granted admin access via internal login
API_INTERNAL_LOGIN_ADMIN_ROLES=admin

# Azure Application Insights connection string (shared with agent-runtime)
APPLICATIONINSIGHTS_CONNECTION_STRING=your-connection-string-here

# OpenTelemetry OTLP exporter endpoint (shared with agent-runtime)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# -----------------------------------------------------------------------------
# agent-runtime — identity & control-plane binding  (apps/agent-runtime)
# -----------------------------------------------------------------------------

# Unique tenant identifier for this runtime instance
AF_TENANT_ID=your-tenant-id

# Tenant identifier used by agent-runtime main process (simple string; defaults to "default")
AGENT_TENANT_ID=default

# Unique workspace identifier for this runtime instance
AF_WORKSPACE_ID=your-workspace-id

# Unique bot/agent identifier for this runtime instance
AF_BOT_ID=your-bot-id

# Role profile name (e.g. "Developer Agent"); drives policy key resolution
AF_ROLE_PROFILE=Developer Agent

# Optional explicit role key override; derived from AF_ROLE_PROFILE if unset
AF_ROLE_KEY=

# Role definition version string
AF_ROLE_VERSION=1.0

# Policy pack version to enforce (e.g. "mvp-v1")
AF_POLICY_PACK_VERSION=mvp-v1

# URL of the approval API (control plane); used for approval intake and heartbeat fallback
AF_APPROVAL_API_URL=http://localhost:3000

# URL of the evidence storage API
AF_EVIDENCE_API_URL=http://localhost:3005

# Optional URL of the connector API; falls back to AF_APPROVAL_API_URL
AF_CONNECTOR_API_URL=

# Optional explicit heartbeat URL; falls back to AF_APPROVAL_API_URL
AF_CONTROL_PLANE_HEARTBEAT_URL=

# Log verbosity level (e.g. "info", "debug", "warn")
AF_LOG_LEVEL=info

# Contract version tag sent with every runtime payload
AF_RUNTIME_CONTRACT_VERSION=1.0

# Optional correlation ID injected into telemetry (defaults to "unknown")
AF_CORRELATION_ID=

# Port for the runtime health-check endpoint
AF_HEALTH_PORT=4001

# Set to "true" to enforce task lease locking
AF_ENFORCE_TASK_LEASE=false

# Lease TTL in seconds when task lease locking is enabled
AF_TASK_LEASE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# agent-runtime — connectivity
# -----------------------------------------------------------------------------

# Port the agent-runtime HTTP server listens on
RUNTIME_PORT=4000

# Externally reachable base URL of this runtime (auto-derived from RUNTIME_PORT if unset)
RUNTIME_BASE_URL=http://localhost:4000

# Base URL of the API gateway (used for callbacks and approval intake)
API_GATEWAY_URL=http://localhost:3000

# URL of the multi-agent dispatch endpoint (optional; enables agent-to-agent dispatch)
AGENT_DISPATCH_URL=http://localhost:3001/dispatch

# URL of the evidence service
EVIDENCE_SERVICE_URL=http://localhost:3005

# Bearer token for authenticating to the evidence service
EVIDENCE_SERVICE_TOKEN=your-secret-here

# -----------------------------------------------------------------------------
# agent-runtime — desktop operator
# -----------------------------------------------------------------------------

# Desktop automation provider: "native" (default) or "playwright"
DESKTOP_OPERATOR=native

# Optional session ID passed to the desktop operator
DESKTOP_OPERATOR_SESSION_ID=

# Local directory for browser session profiles used by the desktop operator
BROWSER_PROFILE_DIR=./data/browser-profiles

# -----------------------------------------------------------------------------
# agent-runtime — LLM provider  (set AF_MODEL_PROVIDER to activate one)
# -----------------------------------------------------------------------------

# LLM provider selection: openai | anthropic | azure_openai | google | xai | mistral | together | github_models | auto
AF_MODEL_PROVIDER=anthropic

# LLM request timeout in milliseconds (optional)
AF_LLM_TIMEOUT_MS=60000

# Default model quality profile when AF_MODEL_PROVIDER=auto: quality_first | speed_first | cost_balanced
AF_DEFAULT_MODEL_PROFILE=quality_first

# --- OpenAI ---
AF_OPENAI_API_KEY=your-secret-here
AF_OPENAI_BASE_URL=https://api.openai.com/v1
AF_OPENAI_MODEL=gpt-4o

# --- Anthropic ---
AF_ANTHROPIC_API_KEY=your-secret-here
AF_ANTHROPIC_BASE_URL=https://api.anthropic.com
AF_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Azure OpenAI ---
AF_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AF_AZURE_OPENAI_API_KEY=your-secret-here
AF_AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Google AI ---
AF_GOOGLE_API_KEY=your-secret-here
AF_GOOGLE_MODEL=gemini-1.5-pro

# --- xAI ---
AF_XAI_API_KEY=your-secret-here
AF_XAI_MODEL=grok-beta

# --- Mistral ---
AF_MISTRAL_API_KEY=your-secret-here
AF_MISTRAL_MODEL=mistral-large-latest

# --- Together AI ---
AF_TOGETHER_API_KEY=your-secret-here
AF_TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# --- GitHub Models ---
AF_GITHUB_MODELS_API_KEY=your-secret-here
AF_GITHUB_MODELS_BASE_URL=https://models.inference.ai.azure.com
AF_GITHUB_MODELS_MODEL=gpt-4o

# --- Chat LLM (Phase 13 — Agent Chat; used by chat-service.ts) ---
# Provider selection for the multi-turn chat feature: "mock" (default) | any OpenAI-compatible provider
LLM_PROVIDER=mock

# Base URL of the OpenAI-compatible chat endpoint used by the chat service
LLM_BASE_URL=http://localhost:11434

# API key for the chat LLM endpoint (leave empty when running Ollama locally)
LLM_API_KEY=

# Model name to request from the chat LLM endpoint
LLM_MODEL=llama3

# Request timeout in milliseconds for chat LLM calls (default 30000)
LLM_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# agent-runtime — token budget
# -----------------------------------------------------------------------------

# Path to the persisted token-budget state JSON file
AF_TOKEN_BUDGET_STATE_PATH=./data/token-budget-state.json

# Daily token spend limit (integer; unset = unlimited)
AF_TOKEN_BUDGET_DAILY_LIMIT=

# Fraction of daily limit at which a warning is emitted (default 0.8)
AF_TOKEN_BUDGET_WARNING_THRESHOLD=0.8

# Fraction of daily limit at which tasks are critically throttled (default 0.9)
AF_TOKEN_BUDGET_CRITICAL_THRESHOLD=0.9

# -----------------------------------------------------------------------------
# agent-runtime — observability & blob storage
# -----------------------------------------------------------------------------

# Local SQLite path for action observability when blob storage is not configured
AGENT_OBSERVABILITY_DB_PATH=./data/observability.db

# Azure Blob Storage account URL for action observability uploads
AGENT_OBSERVABILITY_BLOB_ACCOUNT_URL=https://youraccount.blob.core.windows.net

# Blob container name for action observability
AGENT_OBSERVABILITY_BLOB_CONTAINER=agentfarm-observability

# SAS token with write access to the observability container
AGENT_OBSERVABILITY_BLOB_WRITE_SAS_TOKEN=your-secret-here

# SAS token with read access to the observability container
AGENT_OBSERVABILITY_BLOB_READ_SAS_TOKEN=your-secret-here

# -----------------------------------------------------------------------------
# agent-runtime — notification webhooks
# -----------------------------------------------------------------------------

# Slack incoming webhook URL for runtime event notifications
NOTIFICATION_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# Microsoft Teams incoming webhook URL for runtime event notifications
NOTIFICATION_TEAMS_WEBHOOK_URL=https://your-tenant.webhook.office.com/webhookb2/your/url

# -----------------------------------------------------------------------------
# trigger-service  (apps/trigger-service)
# -----------------------------------------------------------------------------

# Port the trigger-service HTTP server listens on
TRIGGER_SERVICE_PORT=3002

# Path to a JSON file containing full TriggerServiceConfig (highest priority)
TRIGGER_CONFIG_PATH=

# Inline JSON TriggerServiceConfig string (second priority after TRIGGER_CONFIG_PATH)
TRIGGER_CONFIG=

# Single-tenant fallback: tenant identifier
TRIGGER_TENANT_ID=default

# Single-tenant fallback: default agent to route triggers to
TRIGGER_DEFAULT_AGENT_ID=default-agent

# URL of the agent-runtime instance triggers are dispatched to
AGENT_RUNTIME_URL=http://localhost:3001

# Anthropic API key used by trigger-service for AI-assisted routing
ANTHROPIC_API_KEY=your-secret-here

# Anthropic API version used by trigger-service
ANTHROPIC_API_VERSION=2023-06-01

# HMAC secret for verifying inbound webhook signatures (x-hub-signature-256 / x-signature)
WEBHOOK_HMAC_SECRET=your-secret-here

# --- Email trigger source (optional; enabled when EMAIL_IMAP_HOST is set) ---
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_TLS=true
EMAIL_IMAP_USER=agent@example.com
EMAIL_IMAP_PASSWORD=your-secret-here

# --- Slack trigger source (optional; enabled when SLACK_BOT_TOKEN is set) ---
SLACK_BOT_TOKEN=your-secret-here
SLACK_SIGNING_SECRET=your-secret-here

# -----------------------------------------------------------------------------
# website / access control  (apps/website)
# See apps/website/.env.example for the full website-specific variable list.
# Variables below are the subset also consumed at the platform level.
# -----------------------------------------------------------------------------

# Comma-separated superadmin email addresses
AGENTFARM_SUPERADMIN_EMAILS=

# Comma-separated superadmin email domains
AGENTFARM_SUPERADMIN_DOMAINS=

# Comma-separated admin email addresses
AGENTFARM_ADMIN_EMAILS=

# Comma-separated admin email domains
AGENTFARM_ADMIN_DOMAINS=

# Comma-separated company member email addresses
AGENTFARM_COMPANY_EMAILS=

# Comma-separated company member email domains
AGENTFARM_COMPANY_DOMAINS=

# Fallback domain treated as company member when AGENTFARM_DISABLE_COMPANY_FALLBACK is false
AGENTFARM_COMPANY_FALLBACK_DOMAINS=agentfarm.local

# Set to "true" to disable the company fallback domain
AGENTFARM_DISABLE_COMPANY_FALLBACK=false

# Internal URL of the dashboard shown to company members
AGENTFARM_INTERNAL_DASHBOARD_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# dashboard  (apps/dashboard)
# -----------------------------------------------------------------------------

# API gateway base URL used by Next.js proxy routes inside the dashboard
DASHBOARD_API_BASE_URL=http://localhost:3000

# Public-facing API URL consumed by browser-side code in dashboard and website
NEXT_PUBLIC_API_URL=http://localhost:3000

# Comma-separated emails explicitly allowed to sign up
AGENTFARM_ALLOWED_SIGNUP_EMAILS=

# Comma-separated domains explicitly allowed to sign up
AGENTFARM_ALLOWED_SIGNUP_DOMAINS=

# -----------------------------------------------------------------------------
# Connectors / External Services
# -----------------------------------------------------------------------------

# SMTP host for outbound email notifications
SMTP_HOST=smtp.example.com

# SMTP port
SMTP_PORT=587

# SMTP username
SMTP_USER=user@example.com

# SMTP password
SMTP_PASS=your-secret-here

# From address used in outbound emails sent by trigger-service and connector-gateway
SMTP_FROM=noreply@agentfarm.dev

# Base URL of the Voicebox service for voice interaction
VOICEBOX_URL=http://voicebox:17493

# Base URL of the VoxCPM2 voice synthesis service
VOXCPM2_URL=http://localhost:8765

# Model ID served by the Voicebox / VoxCPM2 service
VOXCPM2_MODEL_ID=openbmb/VoxCPM2

# -----------------------------------------------------------------------------
# Payments
# -----------------------------------------------------------------------------

# Stripe secret key (use sk_test_* for development)
STRIPE_SECRET_KEY=your-secret-here

# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=your-secret-here

# Razorpay webhook signing secret
RAZORPAY_WEBHOOK_SECRET=your-secret-here

# Stripe publishable key (exposed to browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-publishable-key-here

# Razorpay key ID
RAZORPAY_KEY_ID=your-secret-here

# Razorpay key secret
RAZORPAY_KEY_SECRET=your-secret-here

# Razorpay key ID exposed to the browser
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-key-id-here

# Zoho Sign OAuth client ID
ZOHO_CLIENT_ID=your-secret-here

# Zoho Sign OAuth client secret
ZOHO_CLIENT_SECRET=your-secret-here

# Zoho Sign webhook verification token
ZOHO_SIGN_WEBHOOK_TOKEN=your-secret-here
