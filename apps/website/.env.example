# Website auth and access policy environment variables
#
# ── Local development setup ──────────────────────────────────────────────────
# 1. Copy this file to .env.local   (never commit .env.local)
# 2. Sign up / sign in at http://localhost:3002/login
# 3. To access the Company Portal (/company), your account email must match one
#    of the company operator rules below.
#
# Dev shortcut: any email ending in @agentfarm.local is allowed by default.
# Just sign up with e.g.  ops@agentfarm.local  and you're in.
#
# To use your real email in dev, add it explicitly:
#   AGENTFARM_COMPANY_EMAILS=you@yourcompany.com
#
# ── Production requirements ──────────────────────────────────────────────────
# Set AGENTFARM_COMPANY_EMAILS and/or AGENTFARM_COMPANY_DOMAINS.
# If both are empty in production, /company portal access is denied for everyone.
# ─────────────────────────────────────────────────────────────────────────────

# Optional role mapping — superadmin and admin email/domain allow-lists
AGENTFARM_SUPERADMIN_EMAILS=
AGENTFARM_SUPERADMIN_DOMAINS=
AGENTFARM_ADMIN_EMAILS=
AGENTFARM_ADMIN_DOMAINS=

# Company portal operator access (required in production)
# Comma-separated lists of individual emails and/or domains.
# Example: AGENTFARM_COMPANY_EMAILS=alice@corp.com,bob@corp.com
# Example: AGENTFARM_COMPANY_DOMAINS=corp.com,ops.corp.com
AGENTFARM_COMPANY_EMAILS=
AGENTFARM_COMPANY_DOMAINS=

# Development fallback — allows @agentfarm.local emails when no explicit rules are set.
# Change this list or set AGENTFARM_DISABLE_COMPANY_FALLBACK=true to tighten dev access.
AGENTFARM_COMPANY_FALLBACK_DOMAINS=agentfarm.local
AGENTFARM_DISABLE_COMPANY_FALLBACK=false

# Optional signup restrictions
AGENTFARM_ALLOWED_SIGNUP_EMAILS=
AGENTFARM_ALLOWED_SIGNUP_DOMAINS=
