{
    "name": "@agentfarm/agent-runtime",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./src/main.ts",
    "types": "./src/main.ts",
    "exports": {
        ".": {
            "types": "./src/main.ts",
            "default": "./src/main.ts"
        },
        "./skill-pipeline.js": {
            "types": "./src/skill-pipeline.ts",
            "default": "./src/skill-pipeline.ts"
        },
        "./skill-scheduler.js": {
            "types": "./src/skill-scheduler.ts",
            "default": "./src/skill-scheduler.ts"
        },
        "./agent-feedback.js": {
            "types": "./src/agent-feedback.ts",
            "default": "./src/agent-feedback.ts"
        },
        "./connector-health-monitor.js": {
            "types": "./src/connector-health-monitor.ts",
            "default": "./src/connector-health-monitor.ts"
        },
        "./repo-knowledge-graph.js": {
            "types": "./src/repo-knowledge-graph.ts",
            "default": "./src/repo-knowledge-graph.ts"
        },
        "./webhook-ingestion.js": {
            "types": "./src/webhook-ingestion.ts",
            "default": "./src/webhook-ingestion.ts"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "node --loader ts-node/esm src/main.ts",
        "start": "node dist/main.js",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "tsx --test src/**/*.test.ts",
        "test:db-smoke": "node --import tsx src/db-snapshot-smoke.ts",
        "test:coverage": "pnpm exec c8 --reporter=text-summary --reporter=json-summary --exclude=src/**/*.test.ts tsx --test src/**/*.test.ts && node ../../scripts/coverage-threshold-check.mjs coverage/coverage-summary.json 80 lines src/runtime-server.ts src/execution-engine.ts src/action-result-writer.ts"
    },
    "devDependencies": {
        "tsx": "^4.20.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.2",
        "vitest": "^2.1.8"
    },
    "dependencies": {
        "@prisma/client": "^6.19.3",
        "@agentfarm/shared-types": "workspace:*",
        "fastify": "^5.2.1"
    }
}