  error
}

enum RetentionPolicyAction {
  never_delete
  manual_delete
  auto_delete_after_days
}

enum RetentionPolicyScope {
  tenant
  workspace
  role
}

enum RetentionPolicyStatus {
  active
  archived
  superseded
}

enum AgentQuestionStatus {
  pending
  answered
  timed_out
}

enum AgentQuestionChannel {
  slack
  teams
  dashboard
}

enum AgentQuestionTimeoutPolicy {
  proceed_with_best_guess
  escalate
  abandon_task
}

enum SubscriptionStatus {
  active
  expired
  suspended
  cancelled
