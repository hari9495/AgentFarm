// Frozen 2026-04-21 — canonical source: planning/engineering-execution-design.md Section 7
enum AuditEventType {
  provisioning_event
  bot_runtime_event
  connector_event
  approval_event
  security_event
  audit_event
}

enum AuditSeverity {
  info
  warn
  error
  critical
}

enum ActionStatus {
  pending
  executing
  completed
  rejected
  failed
}

// Frozen 2026-04-21 — canonical source: planning/engineering-execution-design.md Section 6
enum RiskLevel {
  low
  medium
  high
}

model Tenant {
  id          String       @id @default(cuid())
  name        String
  status      TenantStatus @default(pending)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       TenantUser[]
  workspaces  Workspace[]
}

model TenantUser {
  id           String   @id @default(cuid())
  tenantId     String
  email        String   @unique
  name         String
  passwordHash String
  role         String
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Workspace {
  id        String          @id @default(cuid())
  tenantId  String
  name      String
  status    WorkspaceStatus @default(pending)
  createdAt DateTime        @default(now())
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bot       Bot?
}

model Bot {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  role        String
  status      BotStatus @default(created)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// Frozen 2026-04-21 — canonical source: planning/spec-azure-provisioning-workflow.md
model ProvisioningJob {
  id                String                @id @default(cuid())
  tenantId          String
  workspaceId       String
  botId             String
  planId            String
  runtimeTier       String
  roleType          String
  correlationId     String
  triggerSource     String
  status            ProvisioningJobStatus @default(queued)
  failureReason     String?
  remediationHint   String?
  cleanupResult     String?
  requestedAt       DateTime
  requestedBy       String
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([tenantId])
  @@index([workspaceId])
  @@index([correlationId])
}

// Frozen 2026-04-21 — canonical source: planning/spec-docker-runtime-contract.md
model RuntimeInstance {
  id              String        @id @default(cuid())
  botId           String        @unique
  workspaceId     String
  tenantId        String
  status          RuntimeStatus @default(created)
  contractVersion String
  endpoint        String?
  heartbeatAt     DateTime?
  lastSeenAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
  @@index([workspaceId])
}

// Frozen 2026-04-25 — canonical source: planning/role-bot-sprint-execution-plan.md (Sprint 1)
model BotCapabilitySnapshot {
  id                    String                   @id @default(cuid())
  botId                 String
  tenantId              String
  workspaceId           String
  roleKey               String
  roleVersion           String
  policyPackVersion     String
  allowedConnectorTools String[]
  allowedActions        String[]
  brainConfig           Json
  supportedLanguages    String[]                 @default(["en-US"])
  defaultLanguage       String                   @default("en-US")
  languageTier          String                   @default("base")
  speechProvider        String                   @default("oss")
  translationProvider   String                   @default("oss")
  ttsProvider           String                   @default("oss")
  avatarEnabled         Boolean                  @default(false)
  avatarStyle           String                   @default("audio-only")
  avatarProvider        String                   @default("none")
  avatarLocale          String                   @default("en-US")
  snapshotVersion       Int                      @default(1)
  snapshotChecksum      String?
  source                CapabilitySnapshotSource @default(runtime_freeze)
  frozenAt              DateTime
  createdAt             DateTime                 @default(now())

  @@unique([botId, snapshotVersion])
  @@index([tenantId])
  @@index([workspaceId])
  @@index([botId, frozenAt])
}

// Frozen 2026-04-21 — canonical source: planning/engineering-execution-design.md Section 7
model ActionRecord {
  id                String        @id @default(cuid())
  tenantId          String
  workspaceId       String
  botId             String
  actionType        String
  riskLevel         RiskLevel
  policyPackVersion String
  inputSummary      String
  outputSummary     String?
  status            ActionStatus  @default(pending)
  approvalId        String?
  connectorType     String?
  correlationId     String
  createdAt         DateTime      @default(now())
  completedAt       DateTime?

  @@index([tenantId])
  @@index([botId])
  @@index([correlationId])
}

// Frozen 2026-04-21 — canonical source: planning/engineering-execution-design.md Section 6
model Approval {
  id                       String           @id @default(cuid())
  tenantId                 String
  workspaceId              String
  botId                    String
  taskId                   String
  actionId                 String
  riskLevel                RiskLevel
  actionSummary            String
  requestedBy              String
  approverId               String?
  decision                 ApprovalDecision @default(pending)
  decisionReason           String?
  decisionLatencySeconds   Int? // Supports P95 latency SLA reporting per product-architecture.md Step 8
  policyPackVersion        String
  escalationTimeoutSeconds Int              @default(3600)
  escalatedAt              DateTime?
  createdAt                DateTime         @default(now()) // Immutable after created
  decidedAt                DateTime? // Immutable after set; signals record completion

  @@index([tenantId])
  @@index([workspaceId]) // For dashboard scope filtering per spec-dashboard-data-model.md
  @@index([botId])
  @@index([taskId])
  @@index([decision]) // For pending vs decided filtering
  @@index([riskLevel]) // For risk-based latency SLA queries
  @@index([decisionLatencySeconds]) // For P95 latency analysis
}

