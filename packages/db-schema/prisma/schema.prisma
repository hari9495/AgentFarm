// BROWSER AUDIT SYSTEM (2026-05-07)
// Frozen specification: packages/shared-types/src/audit-ids.ts, browser-audit.ts
// ============================================================================

enum BrowserActionType {
  click
  fill
  navigate
  select
  submit
  key_press
  screenshot
  hover
  scroll
  wait
}

enum SessionAuditStatus {
  running
  completed
  failed
  error
}

enum RetentionPolicyAction {
  never_delete
  manual_delete
  auto_delete_after_days
}

enum RetentionPolicyScope {
  tenant
  workspace
  role
}

enum RetentionPolicyStatus {
  active
  archived
  superseded
}

// Agent session for a task — root of audit hierarchy
model AgentSession {
  id                 String              @id // ses_agt_<agent-short>_<timestamp>_<random>
  tenantId           String              // ten_<random> — root tenant
  agentInstanceId    String              // agt_<tenant-short>_<role>_<random> — agent identity
  taskId             String              // link to existing TaskRecord
  role               String              // agent role (e.g., 'developer')
  recordingId        String              // rec_ses_<session-short>
  recordingUrl       String              // signed URL to .mp4 in blob storage
  startedAt          DateTime
  endedAt            DateTime?
  actionCount        Int                 @default(0)
  status             SessionAuditStatus  @default(running)
  failureReason      String?
  retentionExpiresAt DateTime?           // null = never auto-delete (compliance mode)
  retentionPolicyId  String?             // customer-configured policy ID
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  actions            BrowserActionEvent[]

  @@unique([id]) // Session ID is globally unique
  @@index([tenantId])
  @@index([agentInstanceId])
  @@index([taskId])
  @@index([tenantId, startedAt]) // for compliance period queries
  @@index([status])
  @@index([retentionExpiresAt]) // for cleanup jobs
}

// Individual browser action within a session
model BrowserActionEvent {
  id                    String              @id // act_ses_<session-short>_<sequence>
  sessionId             String              // ses_agt_<agent-short>_<timestamp>_<random>
  tenantId              String              // ten_<random> — embedded for zero-join queries
  agentInstanceId       String              // agt_<tenant-short>_<role>_<random> — embedded ancestry
  sequence              Int                 // 0, 1, 2, ... within session
  actionType            BrowserActionType
  targetSelector        String
  targetText            String
  inputValue            String?
  pageUrl               String
  screenshotBeforeId    String              // scr_<action-id>_before
  screenshotAfterId     String              // scr_<action-id>_after
  screenshotBeforeUrl   String              // signed URL
  screenshotAfterUrl    String              // signed URL
  domSnapshotHashBefore String?
  domSnapshotHashAfter  String?
  networkLog            Json                @default("[]") // NetworkEntry[]
  durationMs            Int
  success               Boolean
  errorMessage          String?
  failureClass          String?
  timestamp             DateTime
  correctnessAssertion  Json?               // { screenshotDiffPercentage, domChangesDetected, ... }
  createdAt             DateTime            @default(now())
  session               AgentSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([id])
  @@index([sessionId]) // reconstruct full session
  @@index([tenantId]) // list all actions for tenant
  @@index([agentInstanceId]) // list all actions by agent
  @@index([tenantId, actionType]) // role-based compliance queries
  @@index([timestamp]) // time-range queries
  @@index([tenantId, timestamp]) // compliance exports
}

// Customer-configured retention policy — determines artifact cleanup
model RetentionPolicy {
  id                 String                @id @default(cuid())
  tenantId           String
  workspaceId        String?
  roleKey            String?               // optional: role-scoped policy
  name               String
  description        String?
  scope              RetentionPolicyScope  @default(tenant)
  action             RetentionPolicyAction @default(never_delete)
  retentionDays      Int?                  // null if action != auto_delete_after_days
  deletionTrigger    String?               // 'user_initiated' | 'scheduled' | 'api_triggered'
  deletionSchedule   String?               // cron expression for scheduled deletions
  effectiveFrom      DateTime
  expiredAt          DateTime?
  status             RetentionPolicyStatus @default(active)
  createdBy          String
  updatedBy          String
  correlationId      String
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([tenantId])
  @@index([tenantId, workspaceId])
  @@index([tenantId, status])
}

// Frozen 2026-05-07 — Agent Question Service (Feature #2)
// Allows agent to ask human a question, park task, resume when answered
enum AgentQuestionStatus {
  pending
  answered
  timed_out
}

enum AgentQuestionChannel {
  slack
  teams
  dashboard
}

enum AgentQuestionTimeoutPolicy {
  proceed_with_best_guess
  escalate
  abandon_task
}

model AgentQuestion {
  id            String                      @id @default(cuid())
  contractVersion String
  tenantId      String
  workspaceId   String
  taskId        String
  botId         String
  question      String
  context       String
  options       String[]                    @default([])
  askedVia      AgentQuestionChannel
  status        AgentQuestionStatus         @default(pending)
  timeoutMs     Int                         @default(14400000) // 4 hours
  onTimeout     AgentQuestionTimeoutPolicy  @default(escalate)
  answer        String?
  answeredBy    String?
  answeredAt    DateTime?
  expiresAt     DateTime
  correlationId String
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  @@index([tenantId])
  @@index([workspaceId])
  @@index([taskId])
  @@index([status])
  @@index([expiresAt])
  @@index([tenantId, status])
}

model TenantMcpServer {
  id          String   @id @default(cuid())
  tenantId    String
  workspaceId String?
  name        String
  url         String
  headers     Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

model TenantLanguageConfig {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  defaultLanguage  String   @default("en")
  ticketLanguage   String   @default("en")
  autoDetect       Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
}

model WorkspaceLanguageConfig {
  id                String   @id @default(cuid())
  tenantId          String
  workspaceId       String
  preferredLanguage String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, workspaceId])
  @@index([tenantId])
}

model UserLanguageProfile {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String
  detectedLanguage  String?
  preferredLanguage String?
  confidence        Float     @default(0.0)
  lastDetectedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([tenantId, userId])
}

// Frozen 2026-05-09 — Meeting transcription pipeline sessions
model MeetingSession {
  id               String    @id @default(cuid())
  tenantId         String
  workspaceId      String
  agentId          String
  meetingUrl       String
  platform         String    // "teams" | "zoom" | "google_meet" | "webex"
  status           String    @default("joining")  // joining | recording | transcribing | summarizing | done | error | deleted
  language         String?
  transcriptRaw    String?   @db.Text
  summaryText      String?   @db.Text
  actionItems      String?   @db.Text  // JSON array string
  agentVoiceId     String?   // VoxCPM2 cloned voice ID for this session
  speakingEnabled  Boolean   @default(false)
  resolvedLanguage String?   // language code e.g. "en", "ja"
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  updatedAt        DateTime  @updatedAt

  @@index([tenantId])
  @@index([workspaceId])
  @@index([tenantId, workspaceId])
  @@index([tenantId, status])
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  priceInr    Int
  priceUsd    Int
  agentSlots  Int
  features    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  orders              Order[]
  tenantSubscriptions TenantSubscription[]
  agentSubscriptions  AgentSubscription[]
}

model Order {
  id                String      @id @default(cuid())
  tenantId          String
  planId            String
  plan              Plan        @relation(fields: [planId], references: [id])
  amountCents       Int
  currency          String
  status            String      @default("pending")
  paymentProvider   String
  providerOrderId   String?
  providerPaymentId String?
  providerSignature String?
  customerEmail     String
  customerCountry   String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  invoice           Invoice?
  contractPdfUrl    String?
  zohoSignRequestId String?
  signatureStatus   String?     @default("pending")
  signedAt          DateTime?
  contractSentAt    DateTime?
}

model Invoice {
  id          String   @id @default(cuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])
  tenantId    String
  number      String   @unique
  amountCents Int
  currency    String
  pdfUrl      String?
  sentAt      DateTime?
  paidAt      DateTime?
  createdAt   DateTime @default(now())
}

model ExternalPluginLoad {
  id              String   @id @default(cuid())
  tenantId        String
  pluginKey       String
  version         String
  status          String
  trustLevel      String
  rejectionReason String?
  loadedAt        DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, pluginKey])
}

model PluginKillSwitch {
  id        String   @id @default(cuid())
  tenantId  String
  pluginKey String
  reason    String?
  killedAt  DateTime @default(now())
  killedBy  String?

  @@unique([tenantId, pluginKey])
}

model PluginAllowlist {
  id           String   @id @default(cuid())
  tenantId     String
  pluginKey    String
  capabilities String[]
  grantedAt    DateTime @default(now())

  @@unique([tenantId, pluginKey])
}

model NotificationLog {
  id           String   @id @default(cuid())
  tenantId     String
  workspaceId  String?
  channel      String
  eventTrigger String
  status       String
  payload      Json?
  error        String?
  sentAt       DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, sentAt])
}

model QualitySignalLog {
  id          String   @id @default(cuid())
  tenantId    String
  workspaceId String
  taskId      String?
  signalType  String?
  source      String?
  score       Float?
  metadata    Json?
  recordedAt  DateTime @default(now())

  @@index([tenantId])
  @@index([workspaceId, taskId])
}

// Billing — subscription lifecycle states
enum SubscriptionStatus {
  active
  expired
  suspended
  cancelled
}

// Billing — who initiated a status transition
enum SubscriptionEventActor {
  system
  payment_webhook
  admin
  customer
}

// Frozen 2026-05-11 — Billing Phase A: tenant-level subscription
// Controls access to the full dashboard and all agents under the tenant.
// Grace period: 3 days after expiresAt before status flips to suspended.
model TenantSubscription {
  id              String             @id @default(cuid())
  tenantId        String             @unique
  planId          String
  plan            Plan               @relation(fields: [planId], references: [id])
  status          SubscriptionStatus @default(active)
  paymentProvider String             // "stripe" | "razorpay"
  startedAt       DateTime
  expiresAt       DateTime
  gracePeriodDays Int                @default(3)
  suspendedAt     DateTime?
  cancelledAt     DateTime?
  reactivatedAt   DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  events          SubscriptionEvent[]
  agentSubs       AgentSubscription[]

  @@index([tenantId])
  @@index([status])
  @@index([expiresAt])
  @@index([tenantId, status])
}

// Frozen 2026-05-11 — Billing Phase A: per-agent subscription add-on
// Allows individual agents to be sold separately or to stay active
// even if the tenant-level plan lapses.
model AgentSubscription {
  id                   String              @id @default(cuid())
  tenantId             String
  agentId              String              // references agent/bot ID
  tenantSubscriptionId String?             // null if standalone agent purchase
  tenantSubscription   TenantSubscription? @relation(fields: [tenantSubscriptionId], references: [id])
  planId               String
  plan                 Plan                @relation(fields: [planId], references: [id])
  status               SubscriptionStatus  @default(active)
  paymentProvider      String              // "stripe" | "razorpay"
  startedAt            DateTime
  expiresAt            DateTime
  gracePeriodDays      Int                 @default(3)
  suspendedAt          DateTime?
  cancelledAt          DateTime?
  reactivatedAt        DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  events               SubscriptionEvent[]

  @@unique([tenantId, agentId])
  @@index([tenantId])
  @@index([agentId])
  @@index([status])
  @@index([expiresAt])
  @@index([tenantId, status])
}

// Frozen 2026-05-11 — Billing Phase A: immutable audit trail of all subscription transitions
// Written on every status change (active→expired, expired→suspended, suspended→active, etc.)
model SubscriptionEvent {
  id                   String                 @id @default(cuid())
  tenantId             String
  tenantSubscriptionId String?
  agentSubscriptionId  String?
  tenantSubscription   TenantSubscription?    @relation(fields: [tenantSubscriptionId], references: [id])
  agentSubscription    AgentSubscription?     @relation(fields: [agentSubscriptionId], references: [id])
  fromStatus           SubscriptionStatus?
  toStatus             SubscriptionStatus
  actor                SubscriptionEventActor
  paymentProvider      String?                // set when actor = payment_webhook
  providerEventId      String?                // Stripe event ID or Razorpay payment ID
  reason               String?
  metadata             Json?
  occurredAt           DateTime               @default(now())

  @@index([tenantId])
  @@index([tenantSubscriptionId])
  @@index([agentSubscriptionId])
  @@index([tenantId, occurredAt])
}

// Frozen 2026-05-11 — Phase 10D: customer-configured outbound webhooks
// Fired when task_completed or task_failed events land in the SSE pipeline.
model OutboundWebhook {
  id           String    @id @default(cuid())
  tenantId     String
  workspaceId  String?
  url          String
  secret       String    // HMAC-SHA256 signing secret — customer stores this to verify
  events       String[]  // e.g. ["task_completed", "task_failed"]
  enabled      Boolean   @default(true)
  failureCount Int       @default(0)
  dlqAt        DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deliveries   OutboundWebhookDelivery[]
  dlqEntries   WebhookDlqEntry[]

  @@index([tenantId])
  @@index([tenantId, enabled])
}

// Frozen 2026-05-11 — Phase 10D: delivery log for each outbound webhook fire
model OutboundWebhookDelivery {
  id             String          @id @default(cuid())
  webhookId      String
  webhook        OutboundWebhook @relation(fields: [webhookId], references: [id])
  tenantId       String
  eventType      String
  payload        Json
  responseStatus Int?
  responseBody   String?
  durationMs     Int?
  success        Boolean
  firedAt        DateTime @default(now())

  @@index([webhookId])
  @@index([tenantId])
  @@index([webhookId, firedAt])
}

// Phase 10D (extended) — DLQ entries for webhooks that exceeded failure threshold
model WebhookDlqEntry {
  id            String    @id @default(cuid())
  webhookId     String
  tenantId      String
  reason        String
  lastPayload   Json
  lastEventType String
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?
  resolvedBy    String?
  webhook       OutboundWebhook @relation(fields: [webhookId], references: [id])

  @@index([tenantId])
  @@index([webhookId])
}

// Phase 12 — Scheduled jobs: cron-based automatic task firing
model ScheduledJob {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  cronExpr    String
  goal        String
  agentId     String?
  enabled     Boolean   @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, enabled])
}

// Phase 13 — Agent Chat: multi-turn conversational sessions with message history
model ChatSession {
  id          String        @id @default(cuid())
  tenantId    String
  agentId     String?
  title       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages    ChatMessage[]
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// Phase 14 — Bot Versioning: user-facing config snapshots for rollback
model BotConfigVersion {
  id                String   @id @default(cuid())
  botId             String
  tenantId          String
  versionNumber     Int
  role              String
  status            String
  roleVersion       String?
  policyPackVersion String?
  brainConfig       Json?
  changeNote        String?
  createdBy         String
  createdAt         DateTime @default(now())
  bot               Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, versionNumber])
  @@index([botId])
  @@index([tenantId])
}

// Phase 15 — Multi-Agent Orchestration
model OrchestrationRun {
  id               String                @id @default(cuid())
  tenantId         String
  workspaceId      String
  coordinatorBotId String
  goal             String
  status           String                @default("running")
  subTaskCount     Int                   @default(0)
  completedCount   Int                   @default(0)
  failedCount      Int                   @default(0)
  result           Json?
  errorSummary     String?
  startedAt        DateTime              @default(now())
  completedAt      DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  dispatches       AgentDispatchRecord[]
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

// Phase 16 — Marketplace: durable skill catalog and install tracking
model MarketplaceListing {
  id          String               @id @default(cuid())
  skillId     String               @unique
  name        String
  description String?
  version     String
  author      String?
  permissions Json                 @default("[]")
  source      String?
  tags        Json                 @default("[]")
  status      String               @default("active")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  installs    MarketplaceInstall[]

  @@index([status])
}

model MarketplaceInstall {
  id                  String             @id @default(cuid())
  tenantId            String
  skillId             String
  listingId           String
  approvedPermissions Json               @default("[]")
  pinVersion          Boolean            @default(false)
  status              String             @default("installed")
  installedAt         DateTime           @default(now())
  uninstalledAt       DateTime?
  listing             MarketplaceListing @relation(fields: [listingId], references: [id])
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, skillId])
  @@index([tenantId])
  @@index([tenantId, status])
}

// Phase 21 — A/B Testing: run two BotConfigVersions against incoming tasks
// and compare outcomes via QualitySignalLog scores.
model AbTest {
  id             String             @id @default(cuid())
  tenantId       String
  botId          String
  name           String
  versionAId     String             // BotConfigVersion id — control
  versionBId     String             // BotConfigVersion id — challenger
  trafficSplit   Float              @default(0.5) // 0.0–1.0, fraction routed to B
  status         String             @default("active") // active | paused | concluded
  conclusionNote String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  assignments    AbTestAssignment[]

  @@index([tenantId])
  @@index([tenantId, botId])
  @@index([tenantId, status])
}

model AbTestAssignment {
  id        String   @id @default(cuid())
  abTestId  String
  abTest    AbTest   @relation(fields: [abTestId], references: [id])
  tenantId  String
  taskId    String   @unique // one assignment per task
  versionId String           // which BotConfigVersion was assigned
  variant   String           // "A" or "B"
  createdAt DateTime @default(now())

  @@index([abTestId])
  @@index([tenantId])
  @@index([taskId])
}

// Phase 22 — Per-agent rate limiting: configurable request cap per bot.
// Enforced at task-dispatch time in the api-gateway runtime-tasks route.
model AgentRateLimit {
  id                String   @id @default(cuid())
  botId             String   @unique   // one config per bot
  tenantId          String
  requestsPerMinute Int      @default(60)
  burstLimit        Int      @default(10) // max concurrent burst
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
}

// Phase 23 — Circuit breaker observability: persists circuit state transitions
// for dashboards and audit. The in-memory state machine in circuit-breaker.ts
// is the source of truth; this model is written asynchronously on state change.
model CircuitBreakerState {
  id            String    @id @default(cuid())
  key           String    @unique  // e.g. "webhook:<webhookId>" or "runtime:agent-runtime"
  tenantId      String
  state         String    @default("closed")  // closed | open | half-open
  failureCount  Int       @default(0)
  lastFailureAt DateTime?
  openedAt      DateTime?
  nextRetryAt   DateTime?
  successCount  Int       @default(0)  // successes accumulated in half-open
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, state])
}

// Phase 24 — Priority task queue for tenant-scoped task ingestion.
// Tasks are enqueued with priority (high | normal | low) and drained by the
// in-process sweep worker in apps/api-gateway/src/lib/task-queue.ts.
model TaskQueueEntry {
  id           String    @id @default(cuid())
  tenantId     String
  workspaceId  String
  botId        String?
  priority     String    @default("normal") // high | normal | low
  status       String    @default("pending") // pending | running | done | cancelled | failed
  payload      Json
  errorMessage String?
  enqueuedAt   DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority, enqueuedAt])
}
