DATABASE_URL=postgresql://agentfarm:agentfarm@localhost:5432/agentfarm
REDIS_URL=redis://localhost:6379
OPA_BASE_URL=http://localhost:8181
API_GATEWAY_PORT=3000

# Website company control plane policy
# Production must set one or both values below.
AGENTFARM_COMPANY_EMAILS=
AGENTFARM_COMPANY_DOMAINS=
# Development fallback controls
AGENTFARM_COMPANY_FALLBACK_DOMAINS=agentfarm.local
AGENTFARM_DISABLE_COMPANY_FALLBACK=false

# Email connector (generic SMTP via connector-gateway)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password

# Desktop operator provider: native | mock | playwright
DESKTOP_OPERATOR=native
# Leave blank to auto-generate a session ID per process start
DESKTOP_OPERATOR_SESSION_ID=

# Salesforce browser automation (workspace_salesforce_* actions)
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_USERNAME=agent@yourcompany.com
SALESFORCE_PASSWORD=

# SAP browser automation (workspace_sap_* actions)
SAP_LOGIN_URL=https://your-sap-instance.com
SAP_USERNAME=AGENTUSER
SAP_PASSWORD=
SAP_CLIENT=100
