// Sprint 3 – F6 PR Auto Driver
model PrDraft {
  id               String    @id @default(cuid())
  tenantId         String
  workspaceId      String
  branch           String
  targetBranch     String?
  changeSummary    String
  linkedIssueIds   Json      @default("[]")
  title            String
  body             String
  checklist        Json      @default("[]")
  reviewersSuggested Json    @default("[]")
  status           String    @default("draft")
  prId             String?
  provider         String?
  labels           Json      @default("[]")
  correlationId    String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tenantId, workspaceId])
  @@index([tenantId, workspaceId, status])
}

// Sprint 3 – F7 CI Failure Triage
model CiTriageReport {
  id                   String    @id @default(cuid())
  tenantId             String
  workspaceId          String
  provider             String
  runId                String
  repo                 String
  branch               String
  failedJobs           Json      @default("[]")
  logRefs              Json      @default("[]")
  status               String    @default("queued")
  rootCauseHypothesis  String?
  reproSteps           Json?
  patchProposal        String?
  confidence           Float?
  blastRadius          String?
  correlationId        String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([tenantId, workspaceId])
  @@index([tenantId, workspaceId, status])
  @@unique([tenantId, workspaceId, runId])
}

